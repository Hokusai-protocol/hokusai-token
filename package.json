{
  "name": "hokusai-token-loop",
  "version": "1.0.0",
  "scripts": {
    "test": "hardhat test",
    "size-contracts": "node scripts/size-contracts.js",
    "deploy:mainnet": "npx hardhat run scripts/deploy-mainnet.js --network mainnet",
    "deploy:sepolia": "npx hardhat run scripts/deploy-sepolia.js --network sepolia",
    "smoke:sepolia": "npx hardhat run scripts/smoke-sepolia-readonly.js --network sepolia",
    "e2e:sepolia:mintrequest": "npx hardhat run scripts/e2e-sepolia-mintrequest.js --network sepolia",
    "test:e2e:sepolia": "SEPOLIA_E2E_READONLY=1 npx hardhat test test/e2e/sepolia-end-to-end.test.js --network sepolia",
    "test-queue": "npx ts-node scripts/test-queue.ts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@openzeppelin/contracts": "^4.9.6",
    "@prb/math": "^4.1.0",
    "dotenv": "^16.5.0",
    "hardhat": "^2.24.2"
  },
  "dependencies": {
    "redis": "^5.8.2"
  }
}

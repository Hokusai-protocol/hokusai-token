# Mainnet Deployment Configuration

# Network
NETWORK=mainnet
CHAIN_ID=1

# RPC Endpoint (Get from Alchemy, Infura, etc.)
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE

# Deployer Wallet (Must be funded with Mainnet ETH)
# Generate new: npx hardhat accounts
# Or use existing test wallet

# Gas Configuration
GAS_MULTIPLIER=1.2
MAX_GAS_PRICE_GWEI=50

# Redis Configuration (for queue testing)
REDIS_URL=redis://master.hokusai-redis-development.lenvj6.use1.cache.amazonaws.com:6379/0

# Contract Addresses (populated after deployment)
MODEL_REGISTRY_ADDRESS=
TOKEN_MANAGER_ADDRESS=
HOKUSAI_TOKEN_ADDRESS=


MAINNET_DEPLOYER_KMS_KEY_ID=alias/hokusai/production/ethereum/mainnet/deployer
MAINNET_DEPLOYER_ADDRESS=0x56cA22006d67e14AA1b7820cE02c6B6205Df0c9e
MAINNET_BACKEND_KMS_KEY_ID=alias/hokusai/production/ethereum/mainnet/submitter
MAINNET_BACKEND_ADDRESS=0xc18D0B6eE049B2B113eE4671cB9C8109192e29E2


# Sepolia Deployment Configuration

# Network
NETWORK=sepolia
CHAIN_ID=11155111

# RPC Endpoint (Get from Alchemy, Infura, etc.)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY_HERE

# Runtime / deploy signers
# Preferred path: KMS role-based aliases with pinned addresses.
AWS_REGION=us-east-1
KMS_DEPLOYER_KEY_ID=alias/hokusai/development/ethereum/sepolia/deployer
KMS_DEPLOYER_EXPECTED_ADDRESS=0xAfA95114441e1E13f67E2E6De5Cd6cF03D57B4Da
KMS_BACKEND_KEY_ID=alias/hokusai/development/ethereum/sepolia/submitter
KMS_BACKEND_EXPECTED_ADDRESS=0xbe2640bB22ae79f0d611aC727036fEBcFB7acf0c

# Dev only, and ONLY as an alternative to the KMS deployer path above.
# When KMS_DEPLOYER_KEY_ID is set, leave this UNSET/commented — signing goes through KMS.
# WARNING: a non-empty stub like `0x...` crashes Hardhat config loading
# ("Invalid account ... private key too short"). Use a real 32-byte key or nothing.
# DEPLOYER_PRIVATE_KEY=

# Etherscan verification (HOK-1700). Required for scripts/verify-all-contracts.js.
# Single multichain key from https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY_HERE

# Gas Configuration
GAS_MULTIPLIER=1.2
MAX_GAS_PRICE_GWEI=50

# Redis Configuration (for queue testing)
REDIS_URL=redis://master.hokusai-redis-development.lenvj6.use1.cache.amazonaws.com:6379/0

# Contract Addresses (populated after deployment)
MODEL_REGISTRY_ADDRESS=
TOKEN_MANAGER_ADDRESS=
HOKUSAI_TOKEN_ADDRESS=
BURN_AUCTION_ADDRESS=

ATTESTER_ADDRESS=0x07bf9b22f516d2D464511219488F019c5dFF5335
ADMIN_SAFE_ADDRESS=0x158B985CC667b4E022AD05B99E89007790da66E2
